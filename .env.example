# Copy this file to .env and fill in local secrets/ports as needed.
# MEMORY_ROOT is optional. If omitted, the project root directory is used.

# Embedding backend. Recommended for this project: vLLM OpenAI-compatible embeddings.
EMBEDDING_PROVIDER=vllm
EMBEDDING_SERVICE_URL=http://127.0.0.1:18083/v1
EMBEDDING_MODEL=bge-m3
EMBEDDING_API_KEY=EMPTY
EMBEDDING_TIMEOUT_SECONDS=60

# Local legacy embedding server settings, only needed when EMBEDDING_PROVIDER=legacy.
EMBEDDING_API_HOST=127.0.0.1
EMBEDDING_API_PORT=18081
BGE_DEVICE=cuda:1
BGE_BATCH_SIZE=16

# Memory API.
MEMORY_API_HOST=127.0.0.1
MEMORY_API_PORT=18082
MEMORY_TOP_K=5
RECENT_TURNS=8

# LLM backend used by the memory system.
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
DEEPSEEK_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_SECONDS=60

# Optional Qwen / DashScope settings for LongMemEval answer generation.
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_API_KEY=
DASHSCOPE_API_KEY=
ALIYUN_MODEL=qwen3.5-27b

# Privacy behavior.
PRIVACY_REJECT_SENSITIVE=true
